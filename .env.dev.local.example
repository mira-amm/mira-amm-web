# Local development environment variables for nx dev:local
# Copy this to .env.dev.local and update with your local contract addresses

# Local Fuel provider endpoint
NEXT_PUBLIC_FUEL_PROVIDER_URL=http://localhost:4000/v1/graphql

# Local Subsquid indexer endpoint  
NEXT_PUBLIC_SUBSQUID_ENDPOINT=http://localhost:4350/graphql

# Local contract addresses (update these after running indexer deployment)
# You can find the current contract IDs in: apps/indexer/mira-binned-liquidity-api/contract-ids.json
NEXT_PUBLIC_LOCAL_PROXY_CONTRACT_ID=0x067239a9a1b4d9d3a055d90bb10a9158defdd90a85a808a855cff09c3676fa86
NEXT_PUBLIC_LOCAL_FUNGIBLE_CONTRACT_ID=0x53876459bec697d96528d00c0edac97048c7f5df5b7d5f62678a49ccef3f0b21
