{
  "name": "mira-dex-ts",
  "version": "1.1.42",
  "description": "TypeScript SDK for Mira DEX",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test:integration": "node scripts/run-integration-tests.js",
    "test:integration:watch": "vitest test/integration/**/*.integration.test.ts",
    "test:unit": "vitest run src/**/*.test.ts",
    "test": "vitest run",
    "deploy:v2-blobs:testnet": "PROVIDER_URL=https://testnet.fuel.network/v1/graphql npx tsx scripts/deploy-v2-blobs.ts",
    "deploy:v2-blobs:mainnet": "PROVIDER_URL=https://mainnet.fuel.network/v1/graphql npx tsx scripts/deploy-v2-blobs.ts"
  },
  "peerDependencies": {
    "fuels": "0.101.2"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "vitest": "^3.2.4"
  }
}
