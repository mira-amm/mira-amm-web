{
  "name": "ts-sdk",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "metadata": {
    "description": "TypeScript SDK for Mira AMM."
  },
  "sourceRoot": "libs/ts-sdk/src",
  "projectType": "library",
  "implicitDependencies": ["!libs/web"],
  "tags": ["sdk", "typescript", "v1"],
  "targets": {
    "build": {
      "dependsOn": ["typegen:scripts", "typegen:contracts"],
      "command": "tsx build.ts",
      "cache": true,
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "typecheck": {
      "dependsOn": ["build"],
      "command": "tsc --noEmit",
      "cache": true,
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "typegen:scripts": {
      "command": "fuels typegen -i './sway_abis/scripts/*/release/*-abi.json' -o ./src/sdk/typegen/scripts --script",
      "cache": true,
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "typegen:contracts": {
      "command": "fuels typegen -i './sway_abis/contracts/*/release/*-abi.json' -o './src/sdk/typegen/contracts'",
      "cache": true,
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "test": {
      "command": "vitest run",
      "cache": true,
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "test:unit": {
      "command": "vitest run src/**/*.test.ts",
      "cache": true,
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "test:integration": {
      "command": "node scripts/run-integration-tests.js",
      "options": {
        "cwd": "libs/ts-sdk"
      }
    },
    "test:integration:watch": {
      "command": "vitest test/integration/**/*.integration.test.ts",
      "options": {
        "cwd": "libs/ts-sdk"
      }
    }
  }
}
